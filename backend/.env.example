APP_NAME="ADNU VoteHub API"
API_PREFIX="/api"

# Supabase PostgreSQL connection string.
# You can use either postgresql://... or postgresql+psycopg://...
DATABASE_URL="postgresql+psycopg://postgres:<password>@<host>:5432/postgres"

# Generate a strong value before production use.
SECRET_KEY="change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=120

ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Development helpers. Keep false for production and Supabase deployments.
AUTO_CREATE_TABLES=false
SEED_ON_STARTUP=false
